#include<stdio.h>
int main(){
    int n ; 
    scanf("%d",&n);
    float a[100];
    for (int i =0 ;i<n;i++){
        printf("a[%d]: ",i);
        scanf("%f",&a[i]);
    }
    int min = a[0] ;
    
    for ( int i = 1 ; i < n ; i++){
        if (a[i]<min){
            min = a[i]; 
        }
    }
    printf("gia tri min la:%d",min);
}

