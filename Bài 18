#include <stdio.h>
#include<math.h>
int songuyento(int a){
    for (int i=2;i<sqrt(a);i++){
        if (a % i ==0){ 
            return 0;
        }
    }
    return 1;
}
int main (){
    int N;
    int mang[100];
    printf("nhap so phan tu n:");
    scanf("%d",&N);
    for(int i=0;i<N;i++){
        printf("phan tu thu %d la",i);
        scanf("%d",&mang[i]);
    }
    int max =-1;
    for(int i=0;i<N;i++){
        if(songuyento(mang[i])){
            if(max<mang[i]){
                max=mang[i];
            }
        }
    }
    printf("max=%d",max);
}
