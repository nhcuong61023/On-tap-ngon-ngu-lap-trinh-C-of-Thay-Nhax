#include <stdio.h>
#include <stdbool.h>
bool IsASC2(int a[], int n)
{
    for (int i = 0; i < n - 1; i++)
    {
        if (a[i] > a[i + 1])
            return false;
    }
    return true;
}
bool IsDESC2(int a[], int n)
{
    for (int i = 0; i < n - 1; i++)
    {
        if (a[i] < a[i + 1])
            return false;
    }
    return true;
}
void check(int a[], int n){
    if(IsASC2(a, n)){
        printf("\nDay so tang dan!");
    }else if(IsDESC2(a, n)){
        printf("\nDay so giam dan!");
    }else{
        printf("\nDay so khong tang khong giam!");
    }
}
int main()
{
    int a[100], i, n;
    printf("\n Nhap n=");
    scanf("%d", &n);
    printf("\n Nhap mang: \n");
    for (i = 0; i < n; i++) {
        printf("A[%d]=", i);
        scanf("%d", &a[i]);
    }
    check(a,n);
}
