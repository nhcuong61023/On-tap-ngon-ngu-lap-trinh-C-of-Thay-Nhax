#include <stdio.h>
int main(){
    int n,i, a[100];
    scanf("%d",&n);
    for (i=0;i<n;i++){
        printf("a[%d]: ",i);
        scanf("%d",&a[i]);
    }
    int abc= a[0];
    int bde = a[0];
    for (i=0;i<n;i++){
           if(abc < a[i]){
               abc = a[i];
           }
       }
    for (i=0;i<n;i++){
        if(bde > a[i]){
            bde = a[i];
        }
    }
    printf("Doan chua tat ca cac gia tri co trong mang la doan: [%d,%d]",bde, abc);
}
