#include <stdio.h>
int main (){
    int N;
    int mang[100];
    printf("nhap so phan tu n:");
    scanf("%d",&N);
    for(int i=0;i<N;i++){
        printf("phan tu thu %d la",i);
        scanf("%d",&mang[i]);
    }
    int dem ; 
    dem = 0 ; 
    for ( int i = 0 ; i<N;i++){
        if (mang[i] % 2 == 0){
            dem++;
        }
    }
    printf("So phan tu chan co trong mang la: %d",dem);
}
